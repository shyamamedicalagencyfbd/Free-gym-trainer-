{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Free Gym Trainer app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "weight": { "type": "number", "description": "The user's current weight in kg." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
